<mvc:View controllerName="rlcreatereservations.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core" displayBlock="true">
    <f:DynamicPage id="pageDetail" toggleHeaderOnTitleClick="true" busy="{viewModel>/busy}" busyIndicatorDelay="0">
        <f:title>
            <f:DynamicPageTitle>
                <f:navigationActions>
                    <Button icon="sap-icon://nav-back" press=".onNavBack" tooltip="{i18n>backBtn}" />
                </f:navigationActions>
                <f:heading>
                    <Title text="{i18n>detailTitle}" />
                </f:heading>
                <f:actions>
                    <Button text="{i18n>approveBtn}" icon="sap-icon://accept" type="Accept" press=".onApprove" visible="{
                            parts: [
                                {path: 'detailModel>/Status'},
                                {path: 'detailModel>/ApprovalLevel'}
                            ],
                            formatter: '.formatter.formatApproveButtonVisible'
                        }" />
                    <Button text="{i18n>rejectBtn}" icon="sap-icon://decline" type="Reject" press=".onReject" visible="{
                            path: 'detailModel>/Status',
                            formatter: '.formatter.formatRejectButtonVisible'
                        }" />
                </f:actions>
                <f:snappedContent>
                    <Text text="{detailModel>/Rsnum}" />
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <form:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12" columnsXL="2" columnsL="2" columnsM="1">
                        <form:content>
                            <core:Title text="{i18n>lblHeaderData}" />
                            <Label text="{i18n>lblRsnum}" />
                            <Text text="{detailModel>/Rsnum}" />
                            <Label text="{i18n>lblGjahr}" />
                            <Text text="{detailModel>/Gjahr}" />
                            <Label text="{i18n>lblCreationDate}" />
                            <Text text="{
                                path: 'detailModel>/CreationDate',
                                formatter: '.formatter.formatAbapDate'
                            }" />
                            <Label text="{i18n>lblCostCenter}" />
                            <Text text="{
                                parts: [
                                    {path: 'detailModel>/Kostl'},
                                    {path: 'detailModel>/KostlDesc'}
                                ],
                                formatter: '.formatter.formatRequesterLabel'
                            }" />
                            <Label text="{i18n>lblRequester}" />
                            <Text text="{
                                parts: [
                                    {path: 'detailModel>/RequesterName'},
                                    {path: 'detailModel>/Requester'}
                                ],
                                formatter: '.formatter.formatRequesterLabel'
                            }" />
                            <Label text="{i18n>lblStatus}" />
                            <ObjectStatus text="{
                                    path: 'detailModel>/Status',
                                    formatter: '.formatter.formatStatusText'
                                }" state="{
                                    path: 'detailModel>/Status',
                                    formatter: '.formatter.formatStatusState'
                                }" />
                            <Label text="{i18n>lblExpectedApprover}" />
                            <Text text="{detailModel>/ExpectedApprover}" />
                            <core:Title text="{i18n>lblBudgetResidual}" />
                            <Label text="{i18n>lblEstimatedAmount}" />
                            <ObjectStatus text="{
                                    parts: [
                                        {path: 'detailModel>/EstimatedAmount'},
                                        {path: 'detailModel>/Currency'}
                                    ],
                                    formatter: '.formatter.formatAmount'
                                }" state="{
                                    parts: [
                                        {path: 'detailModel>/EstimatedAmount'},
                                        {path: 'detailModel>/BudgetResidual'}
                                    ],
                                    formatter: '.formatter.formatBudgetWarningState'
                                }" />
                            <Label text="{i18n>lblBudgetResidual}" />
                            <ObjectStatus text="{
                                    parts: [
                                        {path: 'detailModel>/BudgetResidual'},
                                        {path: 'detailModel>/Currency'}
                                    ],
                                    formatter: '.formatter.formatAmount'
                                }" state="{
                                    parts: [
                                        {path: 'detailModel>/EstimatedAmount'},
                                        {path: 'detailModel>/BudgetResidual'}
                                    ],
                                    formatter: '.formatter.formatBudgetWarningState'
                                }" />
                            <core:Title text="{i18n>lblApprovalStatus}" />
                            <Label text="{i18n>lblLevel1}" />
                            <ObjectStatus text="{
                                    parts: [
                                        {path: 'detailModel>/ApprovalL1Flag'},
                                        {path: 'detailModel>/RejectionL1Flag'},
                                        {path: 'detailModel>/ApprovalL1User'},
                                        {path: 'detailModel>/ApprovalL1Date'}
                                    ],
                                    formatter: '.formatter.formatLevelStatus'
                                }" state="{
                                    parts: [
                                        {path: 'detailModel>/ApprovalL1Flag'},
                                        {path: 'detailModel>/RejectionL1Flag'}
                                    ],
                                    formatter: '.formatter.formatLevelState'
                                }" />
                            <Label text="{i18n>lblRejectedBy}" visible="{= ${detailModel>/RejectionL1Flag} === 'X'}" />
                            <Text text="{detailModel>/RejectionL1Reason}" visible="{= ${detailModel>/RejectionL1Flag} === 'X'}" />
                            <Label text="{i18n>lblLevel2}" />
                            <ObjectStatus text="{
                                    parts: [
                                        {path: 'detailModel>/ApprovalL2Flag'},
                                        {path: 'detailModel>/RejectionL2Flag'},
                                        {path: 'detailModel>/ApprovalL2User'},
                                        {path: 'detailModel>/ApprovalL2Date'}
                                    ],
                                    formatter: '.formatter.formatLevelStatus'
                                }" state="{
                                    parts: [
                                        {path: 'detailModel>/ApprovalL2Flag'},
                                        {path: 'detailModel>/RejectionL2Flag'}
                                    ],
                                    formatter: '.formatter.formatLevelState'
                                }" />
                            <Label text="{i18n>lblRejectedBy}" visible="{= ${detailModel>/RejectionL2Flag} === 'X'}" />
                            <Text text="{detailModel>/RejectionL2Reason}" visible="{= ${detailModel>/RejectionL2Flag} === 'X'}" />
                        </form:content>
                    </form:SimpleForm>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table id="itemsTable" items="{detailModel>/Items}" noDataText="Nessuna posizione." busyIndicatorDelay="0" growing="false" alternateRowColors="true">
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>lblItems}" level="H3" />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column minScreenWidth="Small" demandPopin="false">
                        <Text text="{i18n>lblMaterial}" />
                    </Column>
                    <Column minScreenWidth="Small" demandPopin="false">
                        <Text text="{i18n>lblDescription}" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>lblDivision}" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>lblWarehouse}" />
                    </Column>
                    <Column hAlign="End" minScreenWidth="Small" demandPopin="false">
                        <Text text="{i18n>lblQuantity}" />
                    </Column>
                    <Column hAlign="End" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="{i18n>lblMovingAveragePrice}" />
                    </Column>
                    <Column hAlign="End" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>lblEstimatedValue}" />
                    </Column>
                    <Column hAlign="Center" minScreenWidth="Small" demandPopin="false">
                        <Text text="{i18n>lblDeletionFlag}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Inactive">
                        <cells>
                            <Text text="{
                                path: 'detailModel>Matnr',
                                formatter: '.formatter.formatMatnr'
                            }" />
                            <Text text="{detailModel>MatnrDesc}" />
                            <Text text="{detailModel>Werks}" />
                            <Text text="{detailModel>Lgort}" />
                            <ObjectNumber number="{detailModel>Erfmg}" unit="{detailModel>Erfme}" textAlign="End" />
                            <ObjectNumber number="{detailModel>Verpr}" unit="EUR" textAlign="End" />
                            <ObjectNumber number="{detailModel>EstimatedValue}" unit="EUR" textAlign="End" />
                            <ObjectStatus text="{
                                    path: 'detailModel>DeletionFlag',
                                    formatter: '.formatter.formatDeletionFlag'
                                }" state="{
                                    path: 'detailModel>DeletionFlag',
                                    formatter: '.formatter.formatDeletionFlagState'
                                }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>