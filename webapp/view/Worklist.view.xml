<mvc:View controllerName="rlcreatereservations.controller.Worklist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core" displayBlock="true">
    <Page id="worklistPage" title="{i18n>worklistTitle}" showNavButton="false">
        <subHeader>
            <Toolbar id="filterToolbar">
                <Label text="{i18n>lblGjahr}" />
                <Input id="filterGjahr" value="{viewModel>/filterGjahr}" placeholder="es. 2026" width="6rem" maxLength="4" liveChange=".onFilterLiveChange" />
                <Label text="{i18n>lblCostCenter}" />
                <Input id="filterKostl" value="{viewModel>/filterKostl}" placeholder="CdC" width="8rem" liveChange=".onFilterLiveChange" />
                <Label text="{i18n>lblStatus}" />
                <Select id="filterStatus" selectedKey="{viewModel>/filterStatus}" change=".onFilterLiveChange">
                    <core:Item key="" text="{i18n>filterAll}" />
                    <core:Item key="PENDING" text="{i18n>statusPending}" />
                    <core:Item key="APPROVED_L1" text="{i18n>statusApprovedL1}" />
                    <core:Item key="APPROVED_L2" text="{i18n>statusApprovedL2}" />
                    <core:Item key="REJECTED" text="{i18n>statusRejected}" />
                </Select>
                <Label text="{i18n>lblApprovalLevel}" />
                <Select id="filterLevel" selectedKey="{viewModel>/filterLevel}" change=".onFilterLiveChange">
                    <core:Item key="" text="{i18n>filterAll}" />
                    <core:Item key="L1" text="{i18n>levelL1}" />
                    <core:Item key="L2" text="{i18n>levelL2}" />
                </Select>
                <Label text="{i18n>lblRsnum}" />
                <Input id="filterRsnum" value="{viewModel>/filterRsnum}" placeholder="N° Reservation" width="10rem" liveChange=".onFilterLiveChange" />
                <ToolbarSpacer />
                <Button text="{i18n>resetBtn}" icon="sap-icon://clear-filter" press=".onResetFilters" />
            </Toolbar>
        </subHeader>
        <content>
            <Table id="worklistTable" items="{
                    path: 'reservationModel>/reservations',
                    sorter: {
                        path: 'RequestDate',
                        descending: true
                    }
                }" mode="SingleSelectMaster" selectionChange=".onSelectionChange" noDataText="Nessuna reservation trovata." busyIndicatorDelay="0" busy="{viewModel>/busy}">
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>worklistTitle}" level="H3" />
                        <ToolbarSpacer />
                        <Button id="approveBtn" text="{i18n>approveBtn}" icon="sap-icon://accept" type="Accept" press=".onApprove" enabled="{viewModel>/approveEnabled}" />
                        <Button id="rejectBtn" text="{i18n>rejectBtn}" icon="sap-icon://decline" type="Reject" press=".onReject" enabled="{viewModel>/rejectEnabled}" />
                        <Button id="detailBtn" text="{i18n>detailBtn}" icon="sap-icon://detail-view" press=".onNavToDetail" enabled="{viewModel>/detailEnabled}" />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column width="9rem">
                        <Text text="{i18n>lblReservation}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>lblCostCenter}" />
                    </Column>
                    <Column width="8rem">
                        <Text text="{i18n>lblRequestDate}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>lblRequester}" />
                    </Column>
                    <Column width="9rem" hAlign="End">
                        <Text text="{i18n>lblEstimatedAmount}" />
                    </Column>
                    <Column width="9rem">
                        <Text text="{i18n>lblApprovalLevel}" />
                    </Column>
                    <Column width="9rem">
                        <Text text="{i18n>lblStatus}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>lblExpectedApprover}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onNavToDetail">
                        <cells>
                            <ObjectIdentifier title="{reservationModel>Rsnum}" text="{reservationModel>Gjahr}" />
                            <VBox>
                                <Text text="{reservationModel>Kostl}" />
                                <Text text="{reservationModel>KostlDesc}" class="sapUiTinyMarginTop" />
                            </VBox>
                            <Text text="{
                                path: 'reservationModel>RequestDate',
                                formatter: '.formatter.formatAbapDate'
                            }" />
                            <VBox>
                                <Text text="{reservationModel>RequesterName}" />
                                <Text text="{reservationModel>Requester}" class="sapUiTinyMarginTop" />
                            </VBox>
                            <ObjectNumber number="{reservationModel>EstimatedAmount}" unit="{reservationModel>Currency}" textAlign="End" />
                            <Text text="{
                                path: 'reservationModel>ApprovalLevel',
                                formatter: '.formatter.formatApprovalLevelText'
                            }" />
                            <ObjectStatus text="{
                                    path: 'reservationModel>Status',
                                    formatter: '.formatter.formatStatusText'
                                }" state="{
                                    path: 'reservationModel>Status',
                                    formatter: '.formatter.formatStatusState'
                                }" />
                            <Text text="{reservationModel>ExpectedApprover}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>