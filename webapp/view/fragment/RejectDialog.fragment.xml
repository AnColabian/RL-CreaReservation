<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="rejectDialog" title="{i18n>rejectDialogTitle}" contentWidth="32rem" draggable="true">
        <content>
            <VBox class="sapUiMediumMargin">
                <Label text="{i18n>lblRejectReason}" required="true" />
                <TextArea id="txtRejectReason" value="{viewModel>/rejectReason}" maxLength="50" rows="4" width="100%" valueState="{viewModel>/rejectReasonValueState}" valueStateText="{viewModel>/rejectReasonValueStateText}" liveChange=".onRejectReasonLiveChange" />
                <Text text="{= (${viewModel>/rejectReason} ? ${viewModel>/rejectReason}.length : 0) + ' / 50 caratteri'}" class="sapUiTinyMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <Button text="{i18n>confirmRejectBtn}" type="Reject" press=".onConfirmReject" />
        </beginButton>
        <endButton>
            <Button text="{i18n>cancelBtn}" press=".onCancelReject" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>